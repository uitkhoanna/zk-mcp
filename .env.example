# Cysic Minimax API key (REQUIRED)
# Get your key from: https://token-ai.cysic.xyz
CYSIC_API_KEY=your_cysic_api_key_here

# Optional overrides (defaults shown)
CYSIC_BASE_URL=https://token-ai.cysic.xyz/v1
CYSIC_MODEL=minimax-m3

# Optional: request timeout in milliseconds (default 60000)
CYSIC_TIMEOUT_MS=60000
